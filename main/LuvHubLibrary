function LuvHubUI:Notify(Config)
    local NotifContainer = CG:FindFirstChild("LuvHubNotif")
    if not NotifContainer then
        NotifContainer = Instance.new("Frame")
        NotifContainer.Name = "LuvHubNotif"
        NotifContainer.Parent = CG:FindFirstChild("RobloxGui") or CG
        NotifContainer.Size = UDim2.new(0, 300, 1, -20)
        NotifContainer.Position = UDim2.new(1, -10, 0, 0)
        NotifContainer.AnchorPoint = Vector2.new(1, 0)
        NotifContainer.BackgroundTransparency = 1
        local NLayout = Instance.new("UIListLayout", NotifContainer)
        NLayout.SortOrder = Enum.SortOrder.LayoutOrder
        NLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        NLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
        NLayout.Padding = UDim.new(0, 8)
    end

    local NFrame = Instance.new("Frame", NotifContainer)
    NFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    NFrame.BackgroundTransparency = 0.1
    NFrame.AutomaticSize = Enum.AutomaticSize.XY
    Instance.new("UICorner", NFrame).CornerRadius = UDim.new(0, 6)
    local NStroke = Instance.new("UIStroke", NFrame)
    NStroke.Color = self.Theme.Accent
    
    local NPadding = Instance.new("UIPadding", NFrame)
    NPadding.PaddingTop = UDim.new(0, 8); NPadding.PaddingLeft = UDim.new(0, 10); NPadding.PaddingRight = UDim.new(0, 10)
    
    local NTitle = Instance.new("TextLabel", NFrame)
    NTitle.Text = Config.Title or "Notification"
    NTitle.TextColor3 = self.Theme.Accent
    NTitle.Font = Enum.Font.GothamBold; NTitle.TextSize = 10
    NTitle.BackgroundTransparency = 1; NTitle.Size = UDim2.new(0, 200, 0, 15)
    NTitle.TextXAlignment = Enum.TextXAlignment.Left
    
    local NText = Instance.new("TextLabel", NFrame)
    NText.Text = Config.Text or ""
    NText.TextColor3 = self.Theme.Text
    NText.Font = Enum.Font.Gotham; NText.TextSize = 9
    NText.BackgroundTransparency = 1; NText.Position = UDim2.new(0, 0, 0, 18)
    NText.AutomaticSize = Enum.AutomaticSize.XY; NText.TextWrapped = true
    NText.TextXAlignment = Enum.TextXAlignment.Left

    local PBar = Instance.new("Frame", NFrame)
    PBar.Size = UDim2.new(1, 20, 0, 3); PBar.Position = UDim2.new(0, -10, 0, -8)
    PBar.BackgroundColor3 = Color3.fromRGB(30, 30, 40); PBar.BorderSizePixel = 0

    local PFill = Instance.new("Frame", PBar)
    PFill.Size = UDim2.new(1, 0, 1, 0); PFill.BackgroundColor3 = self.Theme.Accent
    PFill.BorderSizePixel = 0

    NFrame.Position = UDim2.new(1, 50, 0, 0)
    TS:Create(NFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()

    task.spawn(function()
        local dur = Config.Duration or 3
        TS:Create(PFill, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 1, 0)}):Play()
        task.wait(dur)
        TS:Create(NFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(1, 50, 0, 0)}):Play()
        task.wait(0.4)
        NFrame:Destroy()
    end)
end

function LuvHubUI:CreateWindow(Config)
    local Window = {
        Title = Config.Title or "LuvHub UI",
        Tabs = {},
        Theme = self.Theme,
        ToggleKey = Config.ToggleKey or Enum.KeyCode.RightControl,
        IsToggled = true
    }
    setmetatable(Window, self)

    local OldGui = CG:FindFirstChild(Window.Title)
    if OldGui then OldGui:Destroy() end

    local SG = Instance.new("ScreenGui")
    SG.Name = Window.Title
    SG.Parent = CG
    SG.ResetOnSpawn = false
    Window.Gui = SG

    local MF = Instance.new("CanvasGroup", SG)
    MF.Size = UDim2.new(0, 500, 0, 350)
    MF.Position = UDim2.new(0.5, -250, 0.5, -175)
    MF.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    MF.Active = true; MF.Draggable = true
    Instance.new("UICorner", MF).CornerRadius = UDim.new(0, 8)
    Window.MainFrame = MF

    local UIGradient = Instance.new("UIGradient", MF)
    UIGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0.00, self.Theme.Grad1), 
        ColorSequenceKeypoint.new(1.00, self.Theme.Grad2)
    }
    UIGradient.Rotation = 45

    local TopBar = Instance.new("Frame", MF)
    TopBar.Size = UDim2.new(1, 0, 0, 35); TopBar.BackgroundTransparency = 1
    
    local TitleL = Instance.new("TextLabel", TopBar)
    TitleL.Text = Window.Title; TitleL.TextColor3 = self.Theme.Accent
    TitleL.Font = Enum.Font.GothamBlack; TitleL.TextSize = 12
    TitleL.Position = UDim2.new(0, 15, 0, 0); TitleL.Size = UDim2.new(0, 200, 1, 0)
    TitleL.BackgroundTransparency = 1; TitleL.TextXAlignment = Enum.TextXAlignment.Left

    local Sidebar = Instance.new("ScrollingFrame", MF)
    Sidebar.Size = UDim2.new(0, 130, 1, -35); Sidebar.Position = UDim2.new(0, 0, 0, 35)
    Sidebar.BackgroundColor3 = Color3.fromRGB(0, 0, 0); Sidebar.BackgroundTransparency = 0.5
    Sidebar.BorderSizePixel = 0; Sidebar.ScrollBarThickness = 0
    local SideList = Instance.new("UIListLayout", Sidebar); SideList.Padding = UDim.new(0, 2)

    local ContentContainer = Instance.new("Frame", MF)
    ContentContainer.Size = UDim2.new(1, -140, 1, -45)
    ContentContainer.Position = UDim2.new(0, 135, 0, 40)
    ContentContainer.BackgroundTransparency = 1

    Window.Sidebar = Sidebar
    Window.ContentContainer = ContentContainer

    UIS.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == Window.ToggleKey then
            Window.IsToggled = not Window.IsToggled
            MF.Visible = Window.IsToggled
        end
    end)

    return Window
end

function LuvHubUI:CreateTab(Name, Icon)
    local Tab = { ElementsCount = 0 }
    
    local Btn = Instance.new("TextButton", self.Sidebar)
    Btn.Size = UDim2.new(1, 0, 0, 35); Btn.BackgroundTransparency = 1; Btn.Text = ""
    
    local Txt = Instance.new("TextLabel", Btn)
    Txt.Text = (Icon and Icon .. "  " or "") .. Name
    Txt.Font = Enum.Font.GothamBold; Txt.TextSize = 10; Txt.TextColor3 = self.Theme.SubText
    Txt.Size = UDim2.new(1, -15, 1, 0); Txt.Position = UDim2.new(0, 15, 0, 0)
    Txt.BackgroundTransparency = 1; Txt.TextXAlignment = Enum.TextXAlignment.Left

    local Page = Instance.new("ScrollingFrame", self.ContentContainer)
    Page.Size = UDim2.new(1, 0, 1, 0); Page.BackgroundTransparency = 1; Page.Visible = false
    Page.ScrollBarThickness = 2; Page.ScrollBarImageColor3 = self.Theme.Accent
    local PL = Instance.new("UIListLayout", Page); PL.Padding = UDim.new(0, 6)
    
    PL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Page.CanvasSize = UDim2.new(0, 0, 0, PL.AbsoluteContentSize.Y + 10)
    end)

    Btn.MouseButton1Click:Connect(function()
        for _, t in pairs(self.Tabs) do t.Page.Visible = false; t.Txt.TextColor3 = self.Theme.SubText end
        Page.Visible = true; Txt.TextColor3 = self.Theme.Text
    end)

    table.insert(self.Tabs, {Page = Page, Txt = Txt})
    Tab.Page = Page
    Tab.Theme = self.Theme
    setmetatable(Tab, self)
    return Tab
end

