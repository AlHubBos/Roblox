function LuvHubUI:CreateTab(Name, Icon)
    local Tab = { ElementsCount = 0 }
    setmetatable(Tab, LuvHubUI) -- PERBAIKAN BUG OOP DI SINI
    
    local Btn = Instance.new("TextButton", self.Sidebar)
    Btn.Size = UDim2.new(1, 0, 0, 35); Btn.BackgroundTransparency = 1; Btn.Text = ""
    
    local IcoL = Instance.new("TextLabel", Btn)
    IcoL.Text = Icon or ""; IcoL.Size = UDim2.new(0, 30, 1, 0)
    IcoL.TextColor3 = self.Theme.SubText; IcoL.BackgroundTransparency = 1; IcoL.TextSize = 14
    
    local TxtL = Instance.new("TextLabel", Btn)
    TxtL.Text = Name; TxtL.Font = Enum.Font.GothamBold; TxtL.TextSize = 9
    TxtL.TextColor3 = self.Theme.SubText; TxtL.Size = UDim2.new(1, -35, 1, 0)
    TxtL.Position = UDim2.new(0, 32, 0, 0); TxtL.BackgroundTransparency = 1
    TxtL.TextXAlignment = Enum.TextXAlignment.Left

    local Page = Instance.new("ScrollingFrame", self.ContentContainer)
    Page.Size = UDim2.new(1, 0, 1, 0); Page.BackgroundTransparency = 1; Page.Visible = false
    Page.ScrollBarThickness = 2; Page.ScrollBarImageColor3 = self.Theme.Accent
    local PL = Instance.new("UIListLayout", Page); PL.Padding = UDim.new(0, 6)
    Instance.new("UIPadding", Page).PaddingTop = UDim.new(0, 5)
    
    PL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Page.CanvasSize = UDim2.new(0, 0, 0, PL.AbsoluteContentSize.Y + 15)
    end)

    Btn.MouseButton1Click:Connect(function()
        for _, t in pairs(self.Tabs) do t.Page.Visible = false; t.IcoL.TextColor3 = self.Theme.SubText; t.TxtL.TextColor3 = self.Theme.SubText end
        Page.Visible = true; IcoL.TextColor3 = self.Theme.Accent; TxtL.TextColor3 = self.Theme.Text
    end)

    table.insert(self.Tabs, {Page = Page, IcoL = IcoL, TxtL = TxtL})
    Tab.Page = Page
    Tab.Theme = self.Theme
    return Tab
end

