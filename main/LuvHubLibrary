function LuvHubUI:AddSlider(Text, Min, Max, Default, Callback)
    local F = Instance.new("Frame", self.Page)
    F.Size = UDim2.new(1, -10, 0, 45); F.BackgroundColor3 = self.Theme.ElementBg
    F.BackgroundTransparency = self.Theme.ElementTrans; Instance.new("UICorner", F).CornerRadius = UDim.new(0, 4)

    local Lbl = Instance.new("TextLabel", F)
    Lbl.Text = Text; Lbl.TextColor3 = self.Theme.Text; Lbl.Font = Enum.Font.GothamBold; Lbl.TextSize = 10
    Lbl.Size = UDim2.new(0, 150, 0, 20); Lbl.Position = UDim2.new(0, 10, 0, 5)
    Lbl.BackgroundTransparency = 1; Lbl.TextXAlignment = Enum.TextXAlignment.Left

    local Val = Instance.new("TextLabel", F)
    Val.Text = tostring(Default); Val.TextColor3 = self.Theme.Accent; Val.Font = Enum.Font.GothamBold; Val.TextSize = 10
    Val.Size = UDim2.new(0, 50, 0, 20); Val.Position = UDim2.new(1, -60, 0, 5)
    Val.BackgroundTransparency = 1; Val.TextXAlignment = Enum.TextXAlignment.Right

    local SliderBg = Instance.new("Frame", F)
    SliderBg.Size = UDim2.new(1, -20, 0, 6); SliderBg.Position = UDim2.new(0, 10, 0, 30)
    SliderBg.BackgroundColor3 = Color3.fromRGB(50, 50, 60); Instance.new("UICorner", SliderBg).CornerRadius = UDim.new(1, 0)

    local Fill = Instance.new("Frame", SliderBg)
    Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
    Fill.BackgroundColor3 = self.Theme.Accent; Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

    local Dragging = false
    local function Update(Input)
        local Pos = math.clamp((Input.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
        Fill.Size = UDim2.new(Pos, 0, 1, 0)
        local Value = math.floor(Min + ((Max - Min) * Pos))
        Val.Text = tostring(Value)
        pcall(Callback, Value)
    end

    local Btn = Instance.new("TextButton", SliderBg)
    Btn.Size = UDim2.new(1, 0, 1, 0); Btn.BackgroundTransparency = 1; Btn.Text = ""
    Btn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = true; Update(input) end end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end end)
    UIS.InputChanged:Connect(function(input) if Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then Update(input) end end)
end

