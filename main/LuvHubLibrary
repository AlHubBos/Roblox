    Btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25); Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 4)
    
    local KeyName = DefaultKey.Name
    Btn.Text = KeyName; Btn.TextColor3 = self.Theme.Accent; Btn.Font = Enum.Font.GothamBold; Btn.TextSize = 9
    
    local Waiting = false
    Btn.MouseButton1Click:Connect(function()
        Waiting = true
        Btn.Text = "..."
    end)

    UIS.InputBegan:Connect(function(input)
        if Waiting and input.UserInputType == Enum.UserInputType.Keyboard then
            KeyName = input.KeyCode.Name
            Btn.Text = KeyName
            Waiting = false
        elseif not Waiting and input.KeyCode.Name == KeyName then
            pcall(Callback)
        end
    end)
end

function LuvHubUI:AddColorPicker(Text, DefaultColor, Callback)
    local F = Instance.new("Frame", self.Page)
    F.Size = UDim2.new(1, -10, 0, 32); F.BackgroundColor3 = self.Theme.ElementBg
    F.BackgroundTransparency = self.Theme.ElementTrans; Instance.new("UICorner", F).CornerRadius = UDim.new(0, 4)

    local Lbl = Instance.new("TextLabel", F)
    Lbl.Text = Text; Lbl.TextColor3 = self.Theme.Text; Lbl.Font = Enum.Font.GothamBold; Lbl.TextSize = 10
    Lbl.Size = UDim2.new(0, 200, 1, 0); Lbl.Position = UDim2.new(0, 10, 0, 0)
    Lbl.BackgroundTransparency = 1; Lbl.TextXAlignment = Enum.TextXAlignment.Left

    local Dis = Instance.new("Frame", F)
    Dis.Size = UDim2.new(0, 40, 0, 16); Dis.Position = UDim2.new(1, -50, 0.5, -8)
    Dis.BackgroundColor3 = DefaultColor; Instance.new("UICorner", Dis).CornerRadius = UDim.new(0, 4)
    local Stroke = Instance.new("UIStroke", Dis); Stroke.Color = Color3.new(1,1,1); Stroke.Transparency = 0.8
    
    local Btn = Instance.new("TextButton", Dis)
    Btn.Size = UDim2.new(1, 0, 1, 0); Btn.BackgroundTransparency = 1; Btn.Text = ""

    local CTable = {Color3.fromRGB(255,0,0), Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(255,255,0), Color3.fromRGB(0,255,255), Color3.fromRGB(255,0,255), Color3.fromRGB(255,255,255), Color3.fromRGB(0,0,0)}
    local Idx = 1

    Btn.MouseButton1Click:Connect(function()
        Idx = Idx + 1
        if Idx > #CTable then Idx = 1 end
        Dis.BackgroundColor3 = CTable[Idx]
        pcall(Callback, CTable[Idx])
    end)
end

return LuvHubUI
