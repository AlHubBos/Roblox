    local SL = Instance.new("UIListLayout", Scroll); SL.Padding = UDim.new(0, 2)

    local Selected = {}
    local IsOpen = false
    local function Toggle()
        IsOpen = not IsOpen
        TS:Create(F, TweenInfo.new(0.3), {Size = IsOpen and UDim2.new(1, -10, 0, 130) or UDim2.new(1, -10, 0, 32)}):Play()
        Arrow.Text = IsOpen and "-" or "+"
    end

    Head.MouseButton1Click:Connect(Toggle)

    for _, opt in ipairs(Options) do
        local Btn = Instance.new("TextButton", Scroll)
        Btn.Size = UDim2.new(1, 0, 0, 22); Btn.BackgroundTransparency = 1
        Btn.Text = "  " .. opt; Btn.TextColor3 = self.Theme.SubText; Btn.Font = Enum.Font.Gotham; Btn.TextSize = 9
        Btn.TextXAlignment = Enum.TextXAlignment.Left

        local Check = Instance.new("TextLabel", Btn)
        Check.Size = UDim2.new(0, 20, 1, 0); Check.Position = UDim2.new(1, -25, 0, 0)
        Check.BackgroundTransparency = 1; Check.Text = "❌"; Check.Font = Enum.Font.Gotham; Check.TextSize = 9
        Check.TextColor3 = Color3.fromRGB(255, 80, 80)

        local IsSelected = false
        Btn.MouseButton1Click:Connect(function()
            IsSelected = not IsSelected
            Check.Text = IsSelected and "✅" or "❌"
            Check.TextColor3 = IsSelected and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(255, 80, 80)
            Btn.TextColor3 = IsSelected and self.Theme.Accent or self.Theme.SubText
            
            if IsSelected then table.insert(Selected, opt) else
                for i, v in ipairs(Selected) do if v == opt then table.remove(Selected, i); break end end
            end
            Val.Text = #Selected .. " Selected"; pcall(Callback, Selected)
        end)
    end
    Scroll.CanvasSize = UDim2.new(0, 0, 0, SL.AbsoluteContentSize.Y)
end

return LuvHubUI
