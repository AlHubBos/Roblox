function LuvHubUI:Notify(Config)
    local NotifContainer = CG:FindFirstChild("LuvHubNotif")
    if not NotifContainer then
        NotifContainer = Instance.new("Frame")
        NotifContainer.Name = "LuvHubNotif"
        NotifContainer.Parent = CG:FindFirstChild("RobloxGui") or CG
        NotifContainer.Size = UDim2.new(0, 300, 1, -20)
        NotifContainer.Position = UDim2.new(1, -10, 0, 0)
        NotifContainer.AnchorPoint = Vector2.new(1, 0)
        NotifContainer.BackgroundTransparency = 1
        local NLayout = Instance.new("UIListLayout", NotifContainer)
        NLayout.SortOrder = Enum.SortOrder.LayoutOrder
        NLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        NLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
        NLayout.Padding = UDim.new(0, 8)
    end

    local NFrame = Instance.new("Frame", NotifContainer)
    NFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    NFrame.BackgroundTransparency = 0.1
    NFrame.AutomaticSize = Enum.AutomaticSize.XY
    Instance.new("UICorner", NFrame).CornerRadius = UDim.new(0, 6)
    local NStroke = Instance.new("UIStroke", NFrame)
    NStroke.Color = self.Theme.Accent
    
    local NPadding = Instance.new("UIPadding", NFrame)
    NPadding.PaddingTop = UDim.new(0, 8); NPadding.PaddingLeft = UDim.new(0, 10); NPadding.PaddingRight = UDim.new(0, 10)
    
    local NTitle = Instance.new("TextLabel", NFrame)
    NTitle.Text = Config.Title or "Notification"
    NTitle.TextColor3 = self.Theme.Accent
    NTitle.Font = Enum.Font.GothamBold; NTitle.TextSize = 10
    NTitle.BackgroundTransparency = 1; NTitle.Size = UDim2.new(0, 200, 0, 15)
    NTitle.TextXAlignment = Enum.TextXAlignment.Left
    
    local NText = Instance.new("TextLabel", NFrame)
    NText.Text = Config.Text or ""
    NText.TextColor3 = self.Theme.Text
    NText.Font = Enum.Font.Gotham; NText.TextSize = 9
    NText.BackgroundTransparency = 1; NText.Position = UDim2.new(0, 0, 0, 18)
    NText.AutomaticSize = Enum.AutomaticSize.XY; NText.TextWrapped = true
    NText.TextXAlignment = Enum.TextXAlignment.Left

    local PBar = Instance.new("Frame", NFrame)
    PBar.Size = UDim2.new(1, 20, 0, 3); PBar.Position = UDim2.new(0, -10, 0, -8)
    PBar.BackgroundColor3 = Color3.fromRGB(30, 30, 40); PBar.BorderSizePixel = 0

    local PFill = Instance.new("Frame", PBar)
    PFill.Size = UDim2.new(1, 0, 1, 0); PFill.BackgroundColor3 = self.Theme.Accent
    PFill.BorderSizePixel = 0

    NFrame.Position = UDim2.new(1, 50, 0, 0)
    TS:Create(NFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()

    task.spawn(function()
        local dur = Config.Duration or 3
        TS:Create(PFill, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 1, 0)}):Play()
        task.wait(dur)
        TS:Create(NFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(1, 50, 0, 0)}):Play()
        task.wait(0.4)
        NFrame:Destroy()
    end)
end

